<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<%- include('./partials/head') %>

  <body>
    <%- include('./partials/header') %>
      <div class="site-content responsive-container">
        <div class="list">
          <div class="list-header">
            <h2>Game Inventory</h2>
          </div>
          <div class="list-content">
              <div class="flex-row">
                <div class="flex-column">
                  <div class="category">Games: </div>
                  <div class="category">Developers: </div>
                  <div class="category">Platforms: </div>
                  <div class="category">Genres: </div>
                </div>
                <div class="flex-column">
                  <div class="count"><%= counts.game_count %></div>
                  <div class="count"><%= counts.developer_count %></div>
                  <div class="count"><%= counts.platform_count %></div>
                  <div class="count"><%= counts.genre_count %></div>
                </div>
              </div>
          </div>
        </div>
      </div>
      <%- include('./partials/footer') %>
  </body>

</html>