<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<%- include('../partials/head') %>

  <body>
    <%- include('../partials/header') %>
      <div class="site-content" responsive-container">
        <div class="list">
          <div class="list-header">
            <h2><%- title %></h2>
          </div>
          <%- include("../partials/errors.ejs") %>
          <form class="confirm-form" method="post" action="/developers/edit/<%= dev.developer_id %>">
            <div class="flex-row">
            <input type="text" name="name" placeolder="Developer" value="<%= dev.name %>" required />
            <button type="submit" class="button primary big">Submit</button>
          </div>
          </form>
          <hr>
          <form class="confirm-form" method="post" action="/developers/delete/<%= dev.developer_id %>">
            <div class="flex-row center">
              <button type="submit" class="button accent big">Delete</button>
            </div>
          </form>
        </div>
      </div>
      <%- include('../partials/footer') %>
        <script type="text/javascript" src="/scripts/formConfirm.js"></script>
  </body>

</html>