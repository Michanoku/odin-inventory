<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<%- include('../partials/head') %>

  <body>
    <%- include('../partials/header') %>
      <div class="site-content">
        <h2><%- title %></h2>
        <%- include("../partials/errors.ejs") %>
          <form class="confirm-form" method="post" action="/genres/edit/<%= genre.genre_id %>">
            <input type="text" name="name" placeolder="Genre" value="<%= genre.name %>" required />
            <button type="submit">Submit</button>
          </form>
          <form class="confirm-form" method="post" action="/genres/delete/<%= genre.genre_id %>">
            <button type="submit">Delete</button>
          </form>
      </div>
      <%- include('../partials/footer') %>
        <script type="text/javascript" src="/scripts/formConfirm.js"></script>
  </body>

</html>