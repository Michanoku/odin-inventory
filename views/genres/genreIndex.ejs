<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<%- include('../partials/head') %>

  <body>
    <%- include('../partials/header') %>
      <div class="site-content">
        <h2>Genres</h2>
        <% if (genres && genres.length> 0) { %>
          <% genres.forEach((genre)=> { %>
            <div class="genre">
              <div class="flex-row">
                <div>
                  <%= genre.name %>
                </div>
                <div>(<%= genre.game_count %> games)</div>
                <a href="/genres/edit/<%= genre.genre_id %>">Edit</a>
              </div>
            </div>
            <% }) %>
              <% } %>
                <hr>
                <a href="/genres/add">Add</a>
      </div>
      <%- include('../partials/footer') %>
  </body>

</html>